{
    "swagger": "2.0",
    "info": {
        "description": "A production-style fintech backend service for transaction reconciliation and risk analysis.",
        "title": "Reconciliation \u0026 Risk API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8081",
    "basePath": "/",
    "paths": {
        "/risk/{transaction_id}": {
            "get": {
                "description": "Returns the risk score and flags for a specific transaction",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "risk"
                ],
                "summary": "Get risk evaluation",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Transaction ID",
                        "name": "transaction_id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/model.RiskEvaluation"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/settlements": {
            "post": {
                "description": "Creates or updates a settlement record for matching",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "reconciliation"
                ],
                "summary": "Create a settlement record",
                "parameters": [
                    {
                        "description": "Settlement Record",
                        "name": "settlement",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "type": "object"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created"
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "model.RiskEvaluation": {
            "type": "object",
            "properties": {
                "created_at": {
                    "type": "string"
                },
                "flags": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "id": {
                    "type": "string"
                },
                "risk_score": {
                    "type": "integer"
                },
                "transaction_id": {
                    "type": "string"
                }
            }
        }
    }
}